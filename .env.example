# Copy this file to .env.local and fill in values. Vite reads .env.local for the dev UI.

# GEMINI_API_KEY: Optional but required for the "AI insight" button in Smart Insights.
GEMINI_API_KEY=

# Server (npm run dev): defaults keep the app on this PC only.
# PORT=3000
# HOST=127.0.0.1
# Set HOST=0.0.0.0 if you want phones/other PCs on your Wi‑Fi to open http://YOUR_PC_IP:3000

# Strong secret if you expose the server beyond localhost.
# JWT_SECRET=

# Hosted Postgres database URL (required for Vercel and recommended locally too).
# Example (Supabase/Neon): postgres://user:password@host:5432/dbname
DATABASE_URL=
